{
  "name": "coupcats",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "panda:codegen": "cross-env NODE_OPTIONS=--experimental-require-module panda codegen --no-watch",
    "panda:cssgen": "cross-env NODE_OPTIONS=--experimental-require-module panda cssgen --no-watch",
    "dev": "npm run panda:codegen && npm run panda:cssgen && vite",
    "build": "npm run panda:codegen && npm run panda:cssgen && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vis.gl/react-maplibre": "^8.1.0",
    "lucide-react": "^0.460.0",
    "maplibre-gl": "^4.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-map-gl": "^7.1.7",
    "react-router-dom": "^7.14.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@pandacss/dev": "^1.9.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^24.0.0",
    "@types/geojson": "^7946.0.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10"
  }
}
